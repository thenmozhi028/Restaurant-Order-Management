  headerInfo: {
    typeName: 'Order Item',
    typeNamePlural: 'Order Items',
    title: { type: #STANDARD, label: 'Item No', value: 'ItemNo' }
  }
}
annotate entity ZROM_C_ORDER_I with
{
  @UI.facet: [
    {
      id: 'ItemDetails',
      purpose: #STANDARD,
      type: #IDENTIFICATION_REFERENCE,
      label: 'Item Details',
      position: 10
    }
  ]

  @UI: {
    lineItem:       [{ position: 10, label: 'Item No' }],
